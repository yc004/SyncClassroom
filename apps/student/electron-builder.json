{
  "appId": "com.lumesync.student",
  "productName": "LumeSync Student",
  "copyright": "Copyright © 2024",
  "electronVersion": "29.4.6",
  "directories": {
    "output": "../../dist/student",
    "buildResources": "../../shared/build"
  },
  "files": [
    "package.json",
    {
      "from": "electron",
      "to": "electron"
    },
    {
      "from": "public",
      "to": "public"
    },
    {
      "from": "../../shared/public",
      "to": "shared/public"
    },
    {
      "from": "../../shared/build",
      "to": "shared/build"
    },
    {
      "from": "../../packages/engine",
      "to": "packages/engine"
    },
    {
      "from": "../common",
      "to": "common"
    }
  ],
  "extraResources": [
    {
      "from": "../../shared/build/verify-password.exe",
      "to": "verify-password.exe"
    }
  ],
  "extraMetadata": {
    "main": "electron/main.js"
  },
  "asar": true,
  "npmArgs": ["--workspaces=false"],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      }
    ],
    "icon": "../../shared/build/icon-student.ico",
    "requestedExecutionLevel": "asInvoker"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": true,
    "allowElevation": true,
    "warningsAsErrors": false,
    "installerLanguages": [
      "zh_CN"
    ],
    "language": "2052",
    "createDesktopShortcut": false,
    "createStartMenuShortcut": false,
    "include": "../../shared/build/student-installer.nsh",
    "installerIcon": "../../shared/build/icon-student.ico",
    "uninstallerIcon": "../../shared/build/icon-student.ico",
    "installerHeaderIcon": "../../shared/build/icon-student.ico",
    "deleteAppDataOnUninstall": false
  }
}