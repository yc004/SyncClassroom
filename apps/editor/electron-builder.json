{
  "appId": "com.lumesync.editor",
  "productName": "LumeSync Editor",
  "copyright": "Copyright © 2024",
  "electronVersion": "29.4.6",
  "directories": {
    "output": "../../dist/editor",
    "buildResources": "../../shared/build"
  },
  "files": [
    "electron/**",
    "public/**",
    "../../shared/public/**",
    "../../shared/build/**",
    "../../packages/engine/**",
    "../../packages/server/**",
    {
      "from": "../common",
      "to": "common",
      "filter": ["**/*"]
    }
  ],
  "extraMetadata": {
    "main": "electron/main.js"
  },
  "asar": false,
  "npmArgs": ["--workspaces=false"],
  "fileAssociations": [
    {
      "ext": "lume",
      "name": "LumeSync 课件",
      "description": "LumeSync 互动课件文件",
      "icon": "../../shared/build/icon-course.ico"
    }
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      }
    ],
    "requestedExecutionLevel": "asInvoker",
    "icon": "../../shared/build/icon-editor.ico"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "allowElevation": false,
    "installerLanguages": [
      "zh_CN"
    ],
    "language": "2052",
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "LumeSync Editor",
    "installerIcon": "../../shared/build/icon-editor.ico",
    "uninstallerIcon": "../../shared/build/icon-editor.ico",
    "installerHeaderIcon": "../../shared/build/icon-editor.ico"
  }
}