// ========================================================
// 课程内容：文件提交测试
// ========================================================

const { useState, useEffect } = React;

// 测试文本内容（文本文件提交页）
const sampleText = `这是一个文本提交测试示例。

学生可以在这里输入任意文本内容，
然后点击提交按钮将内容保存为文件。

这种提交方式适合：
- 记录学习心得
- 提交编程作业
- 书写答案或笔记
- 其他文本形式的作业
`;

// 表单字段（表格提交页）
interface FormField {
    id: number;
    name: string;
    type: 'text' | 'number' | 'select';
    options?: string[];
}

const formFields: FormField[] = [
    { id: 1, name: '学号', type: 'text' },
    { id: 2, name: '姓名', type: 'text' },
    { id: 3, name: '年龄', type: 'number' },
    { id: 4, name: '班级', type: 'select', options: ['一年级', '二年级', '三年级', '四年级'] },
    { id: 5, name: '兴趣爱好', type: 'text' }
];

// 标题页
function IntroSlide() {
    return (
        <div className="flex flex-col items-center justify-center min-h-full text-center p-8 space-y-8 bg-gradient-to-br from-green-50 via-white to-blue-50">
            <div className="w-32 h-32 bg-gradient-to-br from-green-400 to-blue-500 rounded-full flex items-center justify-center shadow-lg">
                <i className="fas fa-paper-plane text-white text-6xl"></i>
            </div>
            <h1 className="text-5xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-green-600 to-blue-600 tracking-tight">
                文件提交测试
            </h1>
            <h2 className="text-2xl font-bold text-slate-600">
                学生内容提交功能演示
            </h2>
            <p className="max-w-3xl text-lg text-slate-500 leading-relaxed bg-white/80 p-6 rounded-2xl shadow-sm">
                本课件演示学生如何通过课件提交内容给教师端。教师端会自动保存学生的提交内容。
            </p>
        </div>
    );
}

// 测试提交页（文本文件，每个学生一个文件）
function TestSubmitSlide() {
    const [textContent, setTextContent] = useState(sampleText);
    const [fileName, setFileName] = useState('my-answer.txt');
    const [submitted, setSubmitted] = useState(false);
    const [isSubmitting, setIsSubmitting] = useState(false);
    const [submitTime, setSubmitTime] = useState<string | null>(null);

    const handleSubmit = async () => {
        if (!textContent.trim()) {
            alert('请输入文本内容！');
            return;
        }

        if (!fileName.trim()) {
            alert('请输入文件名！');
            return;
        }

        setIsSubmitting(true);

        try {
            // 调用提交 API - 每个学生单独一个文本文件
            await window.CourseGlobalContext.submitContent({
                content: textContent,
                fileName: fileName.endsWith('.txt') ? fileName : `${fileName}.txt`,
                mergeFile: false
            });

            setSubmitTime(new Date().toLocaleString('zh-CN'));
            setSubmitted(true);
            alert('提交成功！');
        } catch (err) {
            console.error('提交失败:', err);
            alert('提交失败，请重试');
        } finally {
            setIsSubmitting(false);
        }
    };

    return (
        <div className="flex flex-col min-h-full p-8 bg-white">
            <h2 className="text-3xl font-bold text-slate-800 mb-6 flex items-center shrink-0">
                <i className="fas fa-file-lines mr-4 text-green-500"></i>
                文本文件提交（单独文件）
            </h2>

            <div className="bg-blue-50 border border-blue-200 rounded-xl p-4 mb-4 shrink-0">
                <h3 className="font-bold text-blue-800 mb-2 flex items-center">
                    <i className="fas fa-info-circle mr-2"></i>说明
                </h3>
                <p className="text-blue-700 text-sm">
                    每个学生提交保存为<strong>单独的文本文件</strong>，适合收集答案、笔记、作业等文本内容
                </p>
            </div>

            {submitted ? (
                <div className="flex-1 flex flex-col items-center justify-center bg-green-50 rounded-2xl p-8 border-2 border-green-200">
                    <div className="w-24 h-24 bg-green-500 rounded-full flex items-center justify-center mb-6">
                        <i className="fas fa-check text-white text-5xl"></i>
                    </div>
                    <h3 className="text-3xl font-bold text-green-700 mb-4">提交成功！</h3>
                    <p className="text-slate-600 text-lg mb-2">你的文件已发送到教师端</p>
                    <p className="text-slate-500">提交时间: {submitTime}</p>
                    <div className="mt-6 bg-white rounded-xl p-4 shadow-sm max-w-2xl">
                        <h4 className="font-bold text-slate-700 mb-3">文件名:</h4>
                        <p className="text-slate-800 mb-4 font-mono bg-slate-100 p-2 rounded">{fileName.endsWith('.txt') ? fileName : `${fileName}.txt`}</p>
                        <h4 className="font-bold text-slate-700 mb-3">文件内容预览:</h4>
                        <pre className="text-slate-600 bg-slate-100 p-3 rounded text-sm whitespace-pre-wrap max-h-60 overflow-auto">{textContent}</pre>
                    </div>
                </div>
            ) : (
                <div className="flex-1 space-y-4 overflow-y-auto">
                    <div className="bg-slate-50 rounded-xl p-5 border border-slate-200">
                        <label className="block text-lg font-semibold text-slate-700 mb-3">
                            文件名
                        </label>
                        <input
                            type="text"
                            value={fileName}
                            onChange={(e) => setFileName(e.target.value)}
                            className="w-full p-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                            placeholder="例如：answer.txt"
                            disabled={isSubmitting}
                        />
                    </div>

                    <div className="bg-slate-50 rounded-xl p-5 border border-slate-200 flex-1">
                        <label className="block text-lg font-semibold text-slate-700 mb-3">
                            文件内容
                        </label>
                        <textarea
                            value={textContent}
                            onChange={(e) => setTextContent(e.target.value)}
                            className="w-full p-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent resize-none font-mono text-sm"
                            rows={12}
                            placeholder="请输入你的文本内容..."
                            disabled={isSubmitting}
                        />
                    </div>
                </div>
            )}

            <div className="mt-6 shrink-0">
                {!submitted && (
                    <button
                        onClick={handleSubmit}
                        disabled={isSubmitting}
                        className={`w-full py-4 px-8 rounded-xl font-bold text-lg transition-all ${
                            isSubmitting
                                ? 'bg-slate-300 text-slate-500 cursor-not-allowed'
                                : 'bg-gradient-to-r from-green-500 to-blue-500 hover:from-green-600 hover:to-blue-600 text-white shadow-lg hover:shadow-xl hover:-translate-y-1'
                        }`}
                    >
                        {isSubmitting ? (
                            <span className="flex items-center justify-center">
                                <i className="fas fa-spinner fa-spin mr-3"></i>
                                提交中...
                            </span>
                        ) : (
                            <span className="flex items-center justify-center">
                                <i className="fas fa-paper-plane mr-3"></i>
                                提交文件
                            </span>
                        )}
                    </button>
                )}
            </div>
        </div>
    );
}

// 快速提交测试页（合并到CSV）
function QuickSubmitSlide() {
    const [text, setText] = useState('');
    const [submitted, setSubmitted] = useState(false);

    const handleSubmit = async () => {
        if (!text.trim()) {
            alert('请输入内容');
            return;
        }

        try {
            // 调用提交 API - 合并到CSV文件
            await window.CourseGlobalContext.submitContent({
                content: text,
                fileName: 'quick-notes.csv',
                mergeFile: true
            });
            setSubmitted(true);
            alert('提交成功！');
        } catch (err) {
            console.error('提交失败:', err);
            alert('提交失败，请重试');
        }
    };

    return (
        <div className="flex flex-col min-h-full p-8 bg-white">
            <h2 className="text-3xl font-bold text-slate-800 mb-6 flex items-center shrink-0">
                <i className="fas fa-bolt mr-4 text-yellow-500"></i>
                快速留言测试（合并CSV）
            </h2>

            <div className="bg-yellow-50 border border-yellow-200 rounded-xl p-6 mb-6 shrink-0">
                <h3 className="font-bold text-yellow-800 mb-2 flex items-center">
                    <i className="fas fa-info-circle mr-2"></i>说明
                </h3>
                <p className="text-yellow-700">
                    这个页面的所有学生提交会<strong>合并到一个 CSV 文件</strong>中，适合收集简短的留言或反馈。
                </p>
                <p className="text-yellow-600 text-sm mt-2">
                    CSV 文件格式：学生IP | 时间 | 留言内容
                </p>
            </div>

            <div className="flex-1 flex flex-col justify-center">
                {submitted ? (
                    <div className="bg-green-50 border-2 border-green-200 rounded-xl p-8 text-center">
                        <i className="fas fa-check-circle text-green-500 text-6xl mb-4"></i>
                        <h3 className="text-2xl font-bold text-green-700 mb-2">留言已提交！</h3>
                        <p className="text-slate-600">教师端已收到你的留言</p>
                    </div>
                ) : (
                    <div className="space-y-4">
                        <textarea
                            value={text}
                            onChange={(e) => setText(e.target.value)}
                            className="w-full p-4 border-2 border-slate-300 rounded-xl focus:ring-2 focus:ring-yellow-500 focus:border-transparent resize-none text-lg"
                            rows={6}
                            placeholder="输入你的留言或问题..."
                        />
                        <button
                            onClick={handleSubmit}
                            className="w-full py-4 px-8 bg-gradient-to-r from-yellow-400 to-orange-500 hover:from-yellow-500 hover:to-orange-600 text-white rounded-xl font-bold text-lg shadow-lg hover:shadow-xl hover:-translate-y-1 transition-all"
                        >
                            <i className="fas fa-paper-plane mr-3"></i>提交留言
                        </button>
                    </div>
                )}
            </div>
        </div>
    );
}

// 表格提交测试页（合并到CSV表格）
function FormSubmitSlide() {
    const [formData, setFormData] = useState<{ [key: number]: string }>({});
    const [submitted, setSubmitted] = useState(false);
    const [isSubmitting, setIsSubmitting] = useState(false);

    const handleInputChange = (fieldId: number, value: string) => {
        setFormData(prev => ({
            ...prev,
            [fieldId]: value
        }));
    };

    const handleSubmit = async () => {
        if (Object.keys(formData).length < formFields.length) {
            alert('请填写所有字段！');
            return;
        }

        setIsSubmitting(true);
        const timestamp = new Date().toISOString();

        try {
            // 构造CSV格式的数据
            const csvRow = formFields.map(f => `"${formData[f.id] || ''}"`).join(',');

            // 调用提交 API - 合并到CSV文件
            await window.CourseGlobalContext.submitContent({
                content: {
                    type: 'form-submission',
                    csvRow: csvRow,
                    submittedAt: timestamp
                },
                fileName: 'student-info.csv',
                mergeFile: true
            });
            setSubmitted(true);
            alert('提交成功！');
        } catch (err) {
            console.error('提交失败:', err);
            alert('提交失败，请重试');
        } finally {
            setIsSubmitting(false);
        }
    };

    return (
        <div className="flex flex-col min-h-full p-8 bg-white">
            <h2 className="text-3xl font-bold text-slate-800 mb-6 flex items-center shrink-0">
                <i className="fas fa-table mr-4 text-purple-500"></i>
                学生信息表（合并CSV）
            </h2>

            <div className="bg-purple-50 border border-purple-200 rounded-xl p-6 mb-6 shrink-0">
                <h3 className="font-bold text-purple-800 mb-2 flex items-center">
                    <i className="fas fa-info-circle mr-2"></i>说明
                </h3>
                <p className="text-purple-700">
                    所有学生的信息会<strong>合并到一个 CSV 表格文件</strong>中，适合收集结构化数据。
                </p>
                <p className="text-purple-600 text-sm mt-2">
                    CSV 文件格式：学号,姓名,年龄,班级,兴趣爱好
                </p>
            </div>

            <div className="flex-1 flex flex-col justify-center">
                {submitted ? (
                    <div className="bg-green-50 border-2 border-green-200 rounded-xl p-8 text-center">
                        <i className="fas fa-check-circle text-green-500 text-6xl mb-4"></i>
                        <h3 className="text-2xl font-bold text-green-700 mb-2">信息已提交！</h3>
                        <p className="text-slate-600">你的信息已添加到学生信息表</p>
                        <div className="mt-6 bg-white rounded-xl p-4 shadow-sm max-w-md mx-auto">
                            <h4 className="font-bold text-slate-700 mb-3">提交的信息预览:</h4>
                            {formFields.map(f => (
                                <div key={f.id} className="mb-2 text-left text-sm">
                                    <span className="font-semibold text-slate-600">{f.name}:</span>
                                    <span className="text-slate-800 ml-2">{formData[f.id] || '-'}</span>
                                </div>
                            ))}
                        </div>
                    </div>
                ) : (
                    <div className="space-y-4">
                        {formFields.map(f => (
                            <div key={f.id} className="bg-slate-50 rounded-xl p-5 border border-slate-200">
                                <label className="block text-lg font-semibold text-slate-700 mb-3">
                                    {f.id}. {f.name}
                                </label>
                                {f.type === 'select' ? (
                                    <select
                                        value={formData[f.id] || ''}
                                        onChange={(e) => handleInputChange(f.id, e.target.value)}
                                        className="w-full p-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-transparent"
                                        disabled={isSubmitting}
                                    >
                                        <option value="">请选择...</option>
                                        {f.options?.map(opt => (
                                            <option key={opt} value={opt}>{opt}</option>
                                        ))}
                                    </select>
                                ) : (
                                    <input
                                        type={f.type}
                                        value={formData[f.id] || ''}
                                        onChange={(e) => handleInputChange(f.id, e.target.value)}
                                        className="w-full p-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-transparent"
                                        placeholder={`请输入${f.name}...`}
                                        disabled={isSubmitting}
                                    />
                                )}
                            </div>
                        ))}
                    </div>
                )}
            </div>

            <div className="mt-6 shrink-0">
                {!submitted && (
                    <button
                        onClick={handleSubmit}
                        disabled={isSubmitting}
                        className={`w-full py-4 px-8 rounded-xl font-bold text-lg transition-all ${
                            isSubmitting
                                ? 'bg-slate-300 text-slate-500 cursor-not-allowed'
                                : 'bg-gradient-to-r from-purple-500 to-pink-500 hover:from-purple-600 hover:to-pink-600 text-white shadow-lg hover:shadow-xl hover:-translate-y-1'
                        }`}
                    >
                        {isSubmitting ? (
                            <span className="flex items-center justify-center">
                                <i className="fas fa-spinner fa-spin mr-3"></i>
                                提交中...
                            </span>
                        ) : (
                            <span className="flex items-center justify-center">
                                <i className="fas fa-file-csv mr-3"></i>
                                提交信息
                            </span>
                        )}
                    </button>
                )}
            </div>
        </div>
    );
}

// 总结页
function SummarySlide() {
    return (
        <div className="flex flex-col min-h-full p-8 bg-gradient-to-br from-blue-50 via-white to-green-50">
            <h2 className="text-3xl font-bold text-slate-800 mb-6 shrink-0 flex items-center">
                <i className="fas fa-flag-checkered mr-4 text-blue-500"></i>
                测试总结
            </h2>

            <div className="flex-1 space-y-6">
                <div className="bg-white rounded-xl p-6 shadow-sm border border-slate-200">
                    <h3 className="text-xl font-bold text-slate-700 mb-4 flex items-center">
                        <i className="fas fa-check-circle text-green-500 mr-3"></i>
                        测试完成检查项
                    </h3>
                    <ul className="space-y-3">
                        <li className="flex items-start">
                            <i className="fas fa-square text-slate-300 mr-3 mt-1"></i>
                            <span className="text-slate-600">文本文件提交页面（单独文件）是否正常提交？</span>
                        </li>
                        <li className="flex items-start">
                            <i className="fas fa-square text-slate-300 mr-3 mt-1"></i>
                            <span className="text-slate-600">快速留言页面（合并CSV）是否正常提交？</span>
                        </li>
                        <li className="flex items-start">
                            <i className="fas fa-square text-slate-300 mr-3 mt-1"></i>
                            <span className="text-slate-600">学生信息表（表格CSV）是否正常提交？</span>
                        </li>
                        <li className="flex items-start">
                            <i className="fas fa-square text-slate-300 mr-3 mt-1"></i>
                            <span className="text-slate-600">教师端是否收到提交的文件？</span>
                        </li>
                        <li className="flex items-start">
                            <i className="fas fa-square text-slate-300 mr-3 mt-1"></i>
                            <span className="text-slate-600">文件是否保存在正确的目录下？</span>
                        </li>
                    </ul>
                </div>

                <div className="bg-blue-50 rounded-xl p-6 border border-blue-200">
                    <h3 className="text-xl font-bold text-blue-700 mb-4 flex items-center">
                        <i className="fas fa-folder-open mr-3"></i>
                        文件存储位置
                    </h3>
                    <p className="text-slate-700">
                        学生提交的文件默认保存在：<code className="bg-white px-2 py-1 rounded text-blue-600">submissions/课程ID/</code>
                    </p>
                    <p className="text-slate-600 mt-2 text-sm">
                        教师端可在设置中自定义存储位置
                    </p>
                </div>

                <div className="bg-green-50 rounded-xl p-6 border border-green-200">
                    <h3 className="text-xl font-bold text-green-700 mb-4 flex items-center">
                        <i className="fas fa-lightbulb mr-3"></i>
                        使用提示
                    </h3>
                    <ul className="space-y-2 text-slate-600">
                        <li>• <strong>单独文本文件</strong>：适合收集文本内容，每个学生一个文件</li>
                        <li>• <strong>合并CSV留言</strong>：适合收集简短留言，所有学生合并到一个文件</li>
                        <li>• <strong>表格CSV</strong>：适合收集结构化数据，可作为Excel打开</li>
                        <li>• CSV文件格式：字段之间用逗号分隔，支持用Excel打开</li>
                        <li>• 提交超时时间为 30 秒</li>
                        <li>• 只有学生端可以提交内容</li>
                    </ul>
                </div>

                <div className="bg-purple-50 rounded-xl p-6 border border-purple-200">
                    <h3 className="text-xl font-bold text-purple-700 mb-4 flex items-center">
                        <i className="fas fa-file-csv mr-3"></i>
                        文件格式说明
                    </h3>
                    <div className="space-y-3 text-sm">
                        <div className="bg-white rounded-lg p-3">
                            <h4 className="font-bold text-purple-800 mb-1">*.txt</h4>
                            <p className="text-slate-600">每个学生一个文件，文件名由学生自定义，内容为纯文本</p>
                        </div>
                        <div className="bg-white rounded-lg p-3">
                            <h4 className="font-bold text-purple-800 mb-1">quick-notes.csv</h4>
                            <p className="text-slate-600">合并文件，格式：学生IP | 时间 | 留言内容</p>
                        </div>
                        <div className="bg-white rounded-lg p-3">
                            <h4 className="font-bold text-purple-800 mb-1">student-info.csv</h4>
                            <p className="text-slate-600">合并文件，格式：学号,姓名,年龄,班级,兴趣爱好</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    );
}

// 幻灯片数组
const mySlides = [
    { id: 'intro', component: <IntroSlide /> },
    { id: 'test-submit', component: <TestSubmitSlide />, scrollable: true }, // 文本输入较长，允许滚动
    { id: 'quick-submit', component: <QuickSubmitSlide /> },
    { id: 'form-submit', component: <FormSubmitSlide />, scrollable: true }, // 表单较长，允许滚动
    { id: 'summary', component: <SummarySlide />, scrollable: true } // 总结页内容较多，允许滚动
];

// 课程数据导出
window.CourseData = {
    title: "文件提交测试",
    icon: "📝",
    desc: "演示学生提交内容功能",
    color: "from-green-500 to-blue-600",
    dependencies: [],
    slides: mySlides
};
