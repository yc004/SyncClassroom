                            {idx + 1}
                        </div>
                        <p className="text-lg text-slate-700 pt-1">{point}</p>
                    </div>
                ))}
            </div>

            <div className="mt-10 text-center">
                <p className="text-slate-600 mb-4">
                    <i className="fas fa-star mr-2 text-yellow-500"></i>
                    感知机虽然简单，但它是现代AI的基础！
                </p>
                <p className="text-sm text-slate-500">
                    继续学习，你会发现更多有趣的AI技术 🚀
                </p>
            </div>
        </div>
    );
}

function QuizSlide() {
    const [selectedAnswers, setSelectedAnswers] = useState({});
    const [submitted, setSubmitted] = useState(false);

    const questions = [
        {
            id: 'q1',
            question: '感知机的主要作用是什么？',
            options: ['做出二元决策（是/否）', '生成图片', '翻译语言', '播放音乐'],
            correct: 0
        },
        {
            id: 'q2',
            question: '感知机学习的过程中，什么会被调整？',
            options: ['输入数据', '权重', '输出格式', '计算速度'],
            correct: 1
        },
        {
            id: 'q3',
            question: '以下哪个是感知机的实际应用？',
            options: ['邮件过滤', '视频编辑', '音乐作曲', '3D建模'],
            correct: 0
        }
    ];

    const handleAnswer = (qId, optIdx) => {
        if (!submitted) {
            setSelectedAnswers({ ...selectedAnswers, [qId]: optIdx });
        }
    };

    const handleSubmit = async () => {
        setSubmitted(true);
        try {
            await window.CourseGlobalContext.submitContent({
                content: {
                    quiz: 'perceptron-intro',
                    answers: selectedAnswers,
                    timestamp: new Date().toISOString()
                },
                fileName: 'quiz-result.json',
                mergeFile: false
            });
        } catch (err) {
            console.error('提交失败:', err);
        }
    };

    const score = Object.entries(selectedAnswers).filter(
        ([qId, optIdx]) => questions.find(q => q.id === qId)?.correct === optIdx
    ).length;

    return (
        <div className="flex flex-col min-h-full p-8 bg-white">
            <h2 className="text-3xl font-bold text-slate-800 mb-8 shrink-0">
                <i className="fas fa-question-circle mr-3 text-blue-500"></i>课堂小测验
            </h2>
            
            <div className="flex-1 space-y-6">
                {questions.map((q, idx) => (
                    <div key={q.id} className="bg-slate-50 p-6 rounded-2xl border border-slate-200">
                        <h3 className="font-bold text-slate-800 mb-4">
                            <span className="bg-blue-500 text-white px-3 py-1 rounded-full text-sm mr-3">第{idx + 1}题</span>
                            {q.question}
                        </h3>
                        <div className="space-y-2">
                            {q.options.map((opt, optIdx) => (
                                <button
                                    key={optIdx}
                                    onClick={() => handleAnswer(q.id, optIdx)}
                                    disabled={submitted}
                                    className={`w-full text-left p-3 rounded-lg border-2 transition-all ${
                                        selectedAnswers[q.id] === optIdx
                                            ? submitted
                                                ? optIdx === q.correct
                                                    ? 'bg-green-100 border-green-500'
                                                    : 'bg-red-100 border-red-500'
                                                : 'bg-blue-100 border-blue-500'
                                            : submitted && optIdx === q.correct
                                            ? 'bg-green-50 border-green-300'
                                            : 'bg-white border-slate-200 hover:border-slate-400'
                                    }`}
                                >
                                    <span className="font-medium">{String.fromCharCode(65 + optIdx)}.</span> {opt}
                                </button>
                            ))}
                        </div>
                    </div>
                ))}
            </div>

            <div className="mt-6 flex gap-4 items-center justify-between">
                <button
                    onClick={handleSubmit}
                    disabled={submitted || Object.keys(selectedAnswers).length < questions.length}
                    className="px-6 py-3 bg-blue-500 hover:bg-blue-600 disabled:bg-gray-300 text-white rounded-xl font-bold transition-colors"
                >
                    {submitted ? '已提交' : '提交答案'}
                </button>
                {submitted && (
                    <div className="text-lg font-bold text-slate-800">
                        得分：<span className={score === questions.length ? 'text-green-600' : 'text-orange-600'}>
                            {score}/{questions.length}
                        </span>
                    </div>
                )}
            </div>
        </div>
    );
}

