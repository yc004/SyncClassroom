function LimitationsSlide() {
    return (
        <div className="flex flex-col min-h-full p-8 bg-white">
            <h2 className="text-3xl font-bold text-slate-800 mb-8 shrink-0">
                <i className="fas fa-exclamation-triangle mr-3 text-red-500"></i>感知机的局限
            </h2>
            
            <div className="flex-1 space-y-6">
                <div className="bg-red-50 p-6 rounded-2xl border-2 border-red-200">
                    <h3 className="font-bold text-red-700 mb-4">感知机不能解决的问题：</h3>
                    
                    <div className="space-y-4">
                        <div className="bg-white p-4 rounded-xl border border-red-100">
                            <h4 className="font-bold text-slate-800 mb-2">❌ 复杂的非线性问题</h4>
                            <p className="text-sm text-slate-600">
                                感知机只能处理"线性可分"的问题。如果数据分布很复杂，感知机就无能为力。
                            </p>
                        </div>

                        <div className="bg-white p-4 rounded-xl border border-red-100">
                            <h4 className="font-bold text-slate-800 mb-2">❌ 需要大量标注数据</h4>
                            <p className="text-sm text-slate-600">
                                感知机需要很多已经标注好的训练数据。如果没有足够的例子，学习效果会很差。
                            </p>
                        </div>

                        <div className="bg-white p-4 rounded-xl border border-red-100">
                            <h4 className="font-bold text-slate-800 mb-2">❌ 容易过拟合</h4>
                            <p className="text-sm text-slate-600">
                                感知机可能会"死记硬背"训练数据，对新数据的判断能力很差。
                            </p>
                        </div>
                    </div>
                </div>

                <div className="bg-blue-50 p-6 rounded-2xl border-2 border-blue-200">
                    <h3 className="font-bold text-blue-700 mb-2">
                        <i className="fas fa-arrow-right mr-2"></i>下一步：神经网络
                    </h3>
                    <p className="text-slate-700 text-sm">
                        为了解决这些问题，科学家们发明了<span className="font-bold">神经网络</span>——把多个感知机连接起来，形成更强大的学习系统。
                    </p>
                </div>
            </div>
        </div>
    );
}

