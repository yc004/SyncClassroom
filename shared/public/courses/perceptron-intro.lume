    { id: 'real-world', component: <RealWorldAppsSlide /> },
    { id: 'learning', component: <LearningSlide /> },
    { id: 'limitations', component: <LimitationsSlide /> },
    { id: 'quiz', component: <QuizSlide /> },
    { id: 'summary', component: <SummarySlide /> }
];

