}

function HowItWorksSlide() {
    return (
        <div className="flex flex-col min-h-full p-8 bg-white">
            <h2 className="text-3xl font-bold text-slate-800 mb-8 shrink-0">
                <i className="fas fa-cogs mr-3 text-blue-500"></i>感知机如何工作？
            </h2>
            
            <div className="flex-1 space-y-6">
                <div className="bg-slate-50 p-6 rounded-2xl border-2 border-slate-200">
                    <h3 className="font-bold text-slate-800 mb-4 text-lg">三个步骤：</h3>
                    
                    <div className="space-y-4">
                        <div className="flex gap-4">
                            <div className="w-12 h-12 bg-purple-500 text-white rounded-full flex items-center justify-center font-bold shrink-0">1</div>
                            <div>
                                <h4 className="font-bold text-slate-800 mb-1">输入信息</h4>
                                <p className="text-slate-600">感知机接收多个信息（特征）。比如判断是否下雨：温度、湿度、风速...</p>
                            </div>
                        </div>

                        <div className="flex gap-4">
                            <div className="w-12 h-12 bg-pink-500 text-white rounded-full flex items-center justify-center font-bold shrink-0">2</div>
                            <div>
                                <h4 className="font-bold text-slate-800 mb-1">计算权重</h4>
                                <p className="text-slate-600">不同信息的重要程度不同。湿度可能比风速更重要，所以给它更大的"权重"。</p>
                            </div>
                        </div>

                        <div className="flex gap-4">
                            <div className="w-12 h-12 bg-blue-500 text-white rounded-full flex items-center justify-center font-bold shrink-0">3</div>
                            <div>
                                <h4 className="font-bold text-slate-800 mb-1">做出决定</h4>
                                <p className="text-slate-600">把所有加权信息加起来，如果超过一个阈值，就输出"是"，否则输出"否"。</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    );
}

function VisualExampleSlide() {
    const [temp, setTemp] = useState(20);
    const [humidity, setHumidity] = useState(50);
    
    const willRain = (temp < 15 && humidity > 70) || (humidity > 85);
    
    return (
        <div className="flex flex-col min-h-full p-8 bg-white">
            <h2 className="text-3xl font-bold text-slate-800 mb-8 shrink-0">
                <i className="fas fa-cloud-rain mr-3 text-cyan-500"></i>实际例子：预测下雨
            </h2>
            
            <div className="flex-1 space-y-6">
                <div className="bg-gradient-to-r from-cyan-50 to-blue-50 p-6 rounded-2xl border-2 border-cyan-200">
                    <h3 className="font-bold text-cyan-700 mb-4">调整参数，看感知机的判断：</h3>
                    
                    <div className="space-y-6">
                        <div>
                            <label className="block font-bold text-slate-700 mb-2">
                                🌡️ 温度：{temp}°C
                            </label>
                            <input
                                type="range"
                                min="0"
                                max="35"
                                value={temp}
                                onChange={(e) => setTemp(Number(e.target.value))}
                                className="w-full h-2 bg-slate-300 rounded-lg appearance-none cursor-pointer"
                            />
                        </div>

                        <div>
                            <label className="block font-bold text-slate-700 mb-2">
                                💧 湿度：{humidity}%
                            </label>
                            <input
                                type="range"
                                min="0"
                                max="100"
                                value={humidity}
                                onChange={(e) => setHumidity(Number(e.target.value))}
                                className="w-full h-2 bg-slate-300 rounded-lg appearance-none cursor-pointer"
                            />
                        </div>
                    </div>
                </div>

                <div className={`p-6 rounded-2xl border-2 text-center transition-all ${
                    willRain 
                        ? 'bg-blue-100 border-blue-400' 
                        : 'bg-yellow-100 border-yellow-400'
                }`}>
                    <div className="text-5xl mb-3">
                        {willRain ? '🌧️' : '☀️'}
                    </div>
                    <p className="text-2xl font-bold text-slate-800">
                        {willRain ? '会下雨！' : '不会下雨'}
                    </p>
                    <p className="text-sm text-slate-600 mt-2">
                        {willRain 
                            ? '温度低且湿度高，或湿度非常高' 
                            : '条件不满足下雨的判断标准'}
                    </p>
                </div>
            </div>
        </div>
    );
}

