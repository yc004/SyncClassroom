{
  "name": "lumesync-workspace",
  "version": "1.0.0",
  "description": "SyncClassroom workspace",
  "private": true,
  "scripts": {
    "repos:init": "git submodule sync --recursive && git submodule update --init --recursive",
    "repos:update": "git submodule update --remote --merge --recursive",
    "start:core": "pnpm --dir repos/core run start",
    "start:teacher": "pnpm --dir repos/teacher run start",
    "start:teacher-server": "pnpm --dir repos/teacher run start:server",
    "start:student": "pnpm --dir repos/student run start",
    "bootstrap:ai-editor": "pnpm --dir repos/ai-editor install --no-frozen-lockfile",
    "build:ai-editor": "pnpm --dir repos/ai-editor run transpile-client",
    "start:ai-editor": "pnpm --dir repos/ai-editor run dev:local-electron",
    "build:verify": "pkg repos/student/shared/build/verify-password.js --target node18-win-x64 --output repos/student/shared/build/verify-password.exe",
    "build:icons": "python repos/teacher/shared/build/convert-icons.py && python repos/student/shared/build/convert-icons.py",
    "build:icons:js": "node repos/teacher/shared/build/convert-icons.js && node repos/student/shared/build/convert-icons.js",
    "start:ai-service": "pnpm --dir repos/ai-editor/services/lumesync-ai-service run start",
    "build:ai-extension:legacy": "pnpm --dir repos/ai-editor/extensions/lumesync-ai run compile",
    "build:preview-extension": "pnpm --dir repos/editor-plugin run compile",
    "install:workspace": "pnpm install --no-frozen-lockfile",
    "install:ai-editor": "pnpm --dir repos/ai-editor install --no-frozen-lockfile",
    "install:all": "pnpm run install:workspace && pnpm run install:ai-editor"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  },
  "packageManager": "pnpm@10.33.0"
}
