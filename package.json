{
  "name": "lumesync-workspace",
  "version": "1.0.0",
  "description": "萤火课堂 - AI-powered face recognition LAN classroom sync tool",
  "private": true,
  "scripts": {
    "repos:init": "git submodule sync --recursive && git submodule update --init --recursive",
    "repos:update": "git submodule update --remote --merge --recursive",
    "start:core": "npm --prefix repos/core run start",
    "start:teacher": "npm --prefix repos/teacher run start",
    "start:teacher-server": "npm --prefix repos/teacher run start:server",
    "start:student": "npm --prefix repos/student run start",
    "build:verify": "pkg repos/student/shared/build/verify-password.js --target node18-win-x64 --output repos/student/shared/build/verify-password.exe",
    "build:icons": "python repos/teacher/shared/build/convert-icons.py && python repos/student/shared/build/convert-icons.py",
    "build:icons:js": "node repos/teacher/shared/build/convert-icons.js && node repos/student/shared/build/convert-icons.js"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  }
}
