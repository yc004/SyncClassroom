{
  "name": "lumesync-workspace",
  "version": "1.0.0",
  "description": "萤火课堂 - AI-powered face recognition LAN classroom sync tool",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "start": "node packages/server/index.js",
    "start:teacher": "cd apps/teacher && npm start",
    "start:student": "cd apps/student && npm start",
    "start:editor": "cd apps/editor && npm start",
    "build:verify": "pkg shared/build/verify-password.js --target node18-win-x64 --output shared/build/verify-password.exe",
    "build:teacher": "cd apps/teacher && node ../../node_modules/electron-builder/cli.js --config electron-builder.json",
    "build:student": "npm run build:verify && cd apps/student && node ../../node_modules/electron-builder/cli.js --config electron-builder.json",
    "build:editor": "cd apps/editor && node ../../node_modules/electron-builder/cli.js --config electron-builder.json",
    "build:all": "npm run build:teacher && npm run build:student && npm run build:editor",
    "build:icons": "python shared/build/convert-icons.py",
    "build:icons:js": "node shared/build/convert-icons.js",
    "migrate": "node migrate-all.js"
  },
  "dependencies": {
    "archiver": "^6.0.1",
    "auto-launch": "^5.0.6",
    "axios": "^1.13.6",
    "builder-util": "^26.8.1",
    "express": "^4.18.2",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "7zip-bin": "^5.2.0",
    "app-builder-bin": "^5.0.0-alpha.12",
    "electron": "^29.4.6",
    "electron-builder": "^24.13.3",
    "node-windows": "^1.0.0-beta.8",
    "pkg": "^5.8.1",
    "png-to-ico": "^3.0.1",
    "socket.io-client": "^4.8.3"
  }
}
