{
  "name": "lumesync",
  "version": "1.0.0",
  "description": "萤火课堂 - AI-powered face recognition LAN classroom sync tool",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "start:teacher": "electron electron/main-teacher.js",
    "start:student": "electron electron/main-student.js",
    "start:editor": "electron electron/main-editor.js",
    "build:verify": "pkg build/verify-password.js --target node18-win-x64 --output build/verify-password.exe",
    "build:teacher": "electron-builder --config electron-builder-teacher.json",
    "build:student": "npm run build:verify && electron-builder --config electron-builder-student.json",
    "build:editor": "electron-builder --config electron-builder-editor.json",
    "build:all": "npm run build:teacher && npm run build:student && npm run build:editor",
    "build:icons": "python build/convert-icons.py"
  },
  "dependencies": {
    "auto-launch": "^5.0.6",
    "express": "^4.18.2",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.9.1",
    "node-windows": "^1.0.0-beta.8",
    "pkg": "^5.8.1",
    "png-to-ico": "^3.0.1"
  }
}
