{
  "appId": "com.lumesync.student",
  "productName": "LumeSync Student",
  "copyright": "Copyright © 2024",
  "directories": {
    "output": "../../dist/student",
    "buildResources": "../../shared/build"
  },
  "files": [
    "electron/**",
    "public/**",
    "../../apps/common/electron/**",
    "../../apps/shared/**",
    "../../packages/engine/**",
    "../../shared/public/**",
    "../../shared/build/**",
    "../../node_modules/auto-launch/**",
    "../../node_modules/winreg/**",
    "../../node_modules/applescript/**",
    "../../node_modules/mkdirp/**",
    "../../node_modules/path-is-absolute/**",
    "../../node_modules/untildify/**",
    "../../node_modules/axios/**",
    "../../node_modules/socket.io-client/**"
  ],
  "extraResources": [
    {
      "from": "../../shared/build/verify-password.exe",
      "to": "verify-password.exe"
    }
  ],
  "extraMetadata": {
    "main": "electron/main.js"
  },
  "asar": true,
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ],
    "icon": "../../shared/build/icon-student.ico",
    "requestedExecutionLevel": "asInvoker"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": true,
    "allowElevation": true,
    "warningsAsErrors": false,
    "installerLanguages": ["zh_CN"],
    "language": "2052",
    "createDesktopShortcut": false,
    "createStartMenuShortcut": false,
    "include": "../../shared/build/student-installer.nsh",
    "installerIcon": "../../shared/build/icon-student.ico",
    "uninstallerIcon": "../../shared/build/icon-student.ico",
    "installerHeaderIcon": "../../shared/build/icon-student.ico",
    "deleteAppDataOnUninstall": false
  }
}
